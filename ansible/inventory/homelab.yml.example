# Copy this file to `homelab.yml` and fill in the IPs from your Terraform output.
# Example: cp ansible/inventory/homelab.yml.example ansible/inventory/homelab.yml

all:
  hosts:
    # Replace with your control plane IP
    <CONTROL_PLANE_IP>:
      ansible_user: <YOUR_SSH_USER>
      ansible_ssh_private_key_file: <PATH_TO_YOUR_SSH_KEY>
  children:
    k3s_cluster:
      hosts:
        # Replace with your control plane IP
        <CONTROL_PLANE_IP>:
        # Replace with your worker node IPs (if any)
        # <WORKER_NODE_1_IP>:
        # <WORKER_NODE_2_IP>:
