apiVersion: v1
kind: Config
current-context: ${cluster_name}
clusters:
- cluster:
    certificate-authority-data: ${cluster_ca}
    server: ${cluster_endpoint}
  name: ${cluster_name}
contexts:
- context:
    cluster: ${cluster_name}
    user: ${cluster_name}-user
  name: ${cluster_name}
users:
- name: ${cluster_name}-user
  user:
    token: ${access_token}
